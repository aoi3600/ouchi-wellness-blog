<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | おうちウェルネス</title>
  <meta name="description" content="{{ description or 'おうちヨガ・ウェルネスで毎日を整える。40〜50代女性のためのリアルな体験ブログ。' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green:       #3a9e78;
      --green-dark:  #2a7a5a;
      --green-light: #eaf6f0;
      --accent:      #f0a500;
      --accent-light:#fff8e6;
      --pink:        #f06292;
      --blue:        #4a90d9;
      --text:        #222;
      --text-sub:    #555;
      --text-muted:  #999;
      --border:      #e5ede9;
      --bg:          #f6faf8;
      --white:       #fff;
      --radius:      12px;
      --radius-sm:   6px;
      --shadow:      0 2px 16px rgba(0,0,0,0.07);
      --shadow-hover:0 8px 28px rgba(0,0,0,0.12);
    }

    body {
      font-family: 'Noto Sans JP', 'Hiragino Kaku Gothic ProN', sans-serif;
      color: var(--text);
      line-height: 1.85;
      background: var(--bg);
      font-size: 15px;
    }
    a { color: var(--green-dark); text-decoration: none; }
    a:hover { color: var(--green); }
    img { max-width: 100%; height: auto; display: block; }

    /* ===== トップバー ===== */
    .top-bar {
      background: var(--green-dark);
      padding: 0.3rem 1.5rem;
      display: flex;
      justify-content: flex-end;
    }
    .top-bar span {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.7);
    }

    /* ===== ヘッダー ===== */
    .site-header {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 1.5rem 1.5rem 1.2rem;
      text-align: center;
    }
    .site-logo {
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--green-dark);
      letter-spacing: 0.04em;
      margin-bottom: 0.3rem;
    }
    .site-logo span { color: var(--accent); }
    .site-desc {
      font-size: 0.82rem;
      color: var(--text-muted);
      letter-spacing: 0.05em;
    }

    /* ===== グローバルナビ ===== */
    .global-nav {
      background: var(--green-dark);
    }
    .global-nav ul {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1.5rem;
      list-style: none;
      display: flex;
      flex-wrap: wrap;
    }
    .global-nav li a {
      display: block;
      padding: 0.75rem 1.3rem;
      color: rgba(255,255,255,0.88);
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      transition: background 0.18s;
    }
    .global-nav li a:hover {
      background: rgba(255,255,255,0.12);
      color: #fff;
    }

    /* ===== メインレイアウト ===== */
    .site-body {
      max-width: 1100px;
      margin: 2rem auto;
      padding: 0 1.5rem;
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 2rem;
      align-items: start;
    }
    .main-content { min-width: 0; }
    .sidebar { min-width: 0; }

    /* ===== サイドバーウィジェット ===== */
    .sidebar-widget {
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 1.4rem;
      margin-bottom: 1.5rem;
      overflow: hidden;
    }
    .widget-title {
      font-size: 0.88rem;
      font-weight: 700;
      color: var(--white);
      background: var(--green-dark);
      margin: -1.4rem -1.4rem 1.2rem;
      padding: 0.65rem 1.2rem;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      letter-spacing: 0.04em;
    }

    /* プロフィール */
    .profile-avatar {
      width: 80px; height: 80px;
      border-radius: 50%;
      background: var(--green-light);
      margin: 0 auto 0.8rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.5rem;
      border: 3px solid var(--green);
    }
    .profile-name {
      text-align: center;
      font-weight: 700;
      font-size: 0.95rem;
      margin-bottom: 0.6rem;
      color: var(--text);
    }
    .profile-badge {
      display: flex;
      justify-content: center;
      gap: 0.4rem;
      flex-wrap: wrap;
      margin-bottom: 0.8rem;
    }
    .badge {
      font-size: 0.72rem;
      padding: 0.15rem 0.6rem;
      border-radius: 20px;
      font-weight: 700;
    }
    .badge-green { background: var(--green-light); color: var(--green-dark); }
    .badge-accent { background: var(--accent-light); color: #b37800; }
    .profile-text { font-size: 0.82rem; color: var(--text-sub); line-height: 1.75; }

    /* カテゴリ */
    .cat-list { list-style: none; }
    .cat-list li {
      border-bottom: 1px dashed var(--border);
    }
    .cat-list li:last-child { border-bottom: none; }
    .cat-list li a {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.55rem 0;
      font-size: 0.85rem;
      color: var(--text-sub);
      transition: color 0.15s;
    }
    .cat-list li a:hover { color: var(--green-dark); }
    .cat-count {
      background: var(--green-light);
      color: var(--green-dark);
      font-size: 0.72rem;
      font-weight: 700;
      padding: 0.1rem 0.5rem;
      border-radius: 20px;
    }

    /* タグクラウド */
    .tag-cloud { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .tag-link {
      font-size: 0.78rem;
      padding: 0.25rem 0.7rem;
      border-radius: 20px;
      border: 1px solid var(--border);
      color: var(--text-sub);
      transition: all 0.15s;
    }
    .tag-link:hover {
      background: var(--green-dark);
      color: var(--white);
      border-color: var(--green-dark);
    }

    /* 最新記事 */
    .recent-list { list-style: none; }
    .recent-list li {
      padding: 0.6rem 0;
      border-bottom: 1px dashed var(--border);
      font-size: 0.83rem;
      line-height: 1.5;
    }
    .recent-list li:last-child { border-bottom: none; }
    .recent-list li a { color: var(--text-sub); }
    .recent-list li a:hover { color: var(--green-dark); }

    /* ===== フッター ===== */
    .site-footer {
      background: var(--green-dark);
      color: rgba(255,255,255,0.7);
      text-align: center;
      padding: 2.5rem 1.5rem;
      margin-top: 3rem;
      font-size: 0.82rem;
    }
    .site-footer a { color: rgba(255,255,255,0.8); }
    .site-footer a:hover { color: #fff; }
    .footer-logo {
      font-size: 1.2rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 0.5rem;
    }

    /* ===== スマホ対応 ===== */
    @media (max-width: 768px) {
      .site-body {
        grid-template-columns: 1fr;
        margin: 1rem auto;
        padding: 0 1rem;
      }
      .sidebar { order: 2; }
      .main-content { order: 1; }
      .global-nav ul { padding: 0 1rem; }
      .site-header { padding: 1.2rem 1rem; }
      .site-logo { font-size: 1.4rem; }
    }
  </style>
</head>
<body>


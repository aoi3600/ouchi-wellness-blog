---
layout: base.njk
---

<style>
  /* パンくず */
  .breadcrumb {
    font-size: 0.78rem;
    color: var(--gray3);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--gray3); }
  .breadcrumb a:hover { color: var(--black); }

  /* アイキャッチ */
  .post-eyecatch {
    width: 100%;
    height: 360px;
    object-fit: cover;
    border-radius: var(--radius);
    margin-bottom: 1.5rem;
    display: block;
    box-shadow: var(--shadow);
  }

  /* 記事ヘッダー */
  .post-header { margin-bottom: 2rem; }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.78rem;
    color: var(--gray3);
    margin-bottom: 0.8rem;
  }
  .post-cat-label {
    background: var(--black);
    color: var(--white);
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.15rem 0.7rem;
    letter-spacing: 0.04em;
  }
  .post-title {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.65;
    color: var(--black);
    border-bottom: 1px solid var(--gray4);
    padding-bottom: 1.2rem;
  }

  /* 記事本文 */
  .post-body {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--black);
    margin-bottom: 2rem;
  }
  .post-body h2 {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--black);
    background: var(--gray5);
    padding: 0.7rem 1.1rem;
    border-left: 4px solid var(--black);
    margin: 2.5rem 0 1rem;
  }
  .post-body h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--black);
    padding: 0.4rem 0 0.4rem 0.8rem;
    border-left: 3px solid var(--accent);
    margin: 2rem 0 0.8rem;
  }
  .post-body p { margin-bottom: 1.1rem; }
  .post-body ul, .post-body ol {
    padding-left: 1.6rem;
    margin-bottom: 1.1rem;
  }
  .post-body li { margin-bottom: 0.4rem; }
  .post-body hr {
    border: none;
    border-top: 1px solid var(--gray4);
    margin: 2.5rem 0;
  }
  .post-body strong { font-weight: 700; }

  /* タグ */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--gray4);
  }
  .post-tag {
    font-size: 0.75rem;
    padding: 0.2rem 0.7rem;
    border: 1px solid var(--gray4);
    color: var(--gray2);
    transition: all 0.15s;
  }
  .post-tag::before { content: "#"; }
  .post-tag:hover {
    background: var(--black);
    color: var(--white);
    border-color: var(--black);
  }

  /* CTAボックス */
  .post-cta {
    background: var(--gray5);
    border: 1px solid var(--gray4);
    border-radius: var(--radius);
    padding: 2rem;
    text-align: center;
    margin-bottom: 2rem;
  }
  .cta-title {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
    color: var(--black);
  }
  .cta-text {
    font-size: 0.85rem;
    color: var(--gray2);
    margin-bottom: 1.3rem;
    line-height: 1.7;
  }
  .cta-btn {
    display: inline-block;
    background: var(--black);
    color: var(--white) !important;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.8rem 2.2rem;
    letter-spacing: 0.04em;
    transition: background 0.2s, transform 0.15s;
  }
  .cta-btn:hover {
    background: var(--accent);
    transform: translateY(-2px);
  }
  .cta-note {
    font-size: 0.72rem;
    color: var(--gray3);
    margin-top: 0.8rem;
  }

  /* 戻るリンク */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
    color: var(--gray2);
    border: 1px solid var(--gray4);
    padding: 0.45rem 1rem;
    transition: all 0.15s;
  }
  .back-link:hover {
    background: var(--black);
    color: var(--white);
    border-color: var(--black);
  }
</style>

<!-- パンくず -->
<nav class="breadcrumb">
  <a href="/">ホーム</a>
  <span>›</span>
  <a href="/">ヨガ体験談</a>
  <span>›</span>
  <span>{{ title }}</span>
</nav>

<!-- アイキャッチ -->
<img class="post-eyecatch"
  src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=1200&h=720&q=80"
  alt="{{ title }}">

<!-- 記事ヘッダー -->
<div class="post-header">
  <div class="post-meta">
    <span class="post-cat-label">ヨガ体験談</span>
    <span>{{ date | dateJP }}</span>
    <span>ひかる</span>
  </div>
  <h1 class="post-title">{{ title }}</h1>
</div>

<!-- 本文 -->
<div class="post-body">
  {{ content | safe }}
</div>

<!-- タグ -->
<div class="post-tags">
  <a href="/" class="post-tag">SOELU</a>
  <a href="/" class="post-tag">オンラインヨガ</a>
  <a href="/" class="post-tag">初心者</a>
  <a href="/" class="post-tag">体が硬い</a>
  <a href="/" class="post-tag">ウェルネス</a>
</div>

<!-- CTA -->
<div class="post-cta">
  <div class="cta-title">まず無料体験から始めてみませんか？</div>
  <p class="cta-text">体が硬くても、体調不安でも大丈夫。<br>私がそうだったから、自信を持って言えます🍀</p>
  <a href="#" class="cta-btn">SOELUを無料で試してみる</a>
  <p class="cta-note">※ こちらにアフィリエイトリンクを挿入してください</p>
</div>

<a href="/" class="back-link">← 記事一覧に戻る</a>

---
layout: base.njk
title: ホーム
description: おうちヨガ・ウェルネスで毎日を整える。40〜50代女性のためのリアルな体験ブログ。
---

<style>
  /* ===== SWELL風 横スクロールスライダー ===== */
  .slider-section {
    margin: 0 -1.5rem 2.5rem;
    position: relative;
    overflow: hidden;
    background: var(--blush-light);
  }
  .slider-track {
    display: flex;
    transition: transform 0.45s ease;
    cursor: grab;
  }
  .slider-track:active { cursor: grabbing; }

  /* 1枚あたり約33.33%幅 → 3枚見える */
  .slide {
    min-width: calc(100% / 3 - 2px);
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }
  .slide-img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  .slide:hover .slide-img { transform: scale(1.03); }

  .slide-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(75,59,71,0.72));
    padding: 1.5rem 1rem 0.9rem;
  }
  .slide-cat {
    display: inline-block;
    background: var(--white);
    color: var(--mauve);
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.1rem 0.55rem;
    margin-bottom: 0.4rem;
    letter-spacing: 0.03em;
  }
  .slide-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* スライダーナビ */
  .slider-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.7rem 0;
    background: var(--white);
    border-bottom: 1px solid var(--border);
  }
  .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--blush);
    border: none; cursor: pointer;
    transition: background 0.2s;
    padding: 0;
  }
  .dot.active { background: var(--mauve); }

  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-60%);
    background: rgba(255,255,255,0.88);
    border: none;
    width: 32px; height: 32px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    color: var(--mauve);
    box-shadow: var(--shadow);
  }
  .slider-btn:hover { background: var(--white); }
  .slider-btn.prev { left: 0.6rem; }
  .slider-btn.next { right: 0.6rem; }

  /* ===== タブ ===== */
  .tab-wrap {
    display: flex;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }
  .tab-btn {
    padding: 0.65rem 1.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--grey-olive);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: all 0.15s;
    font-family: 'Noto Sans JP', sans-serif;
  }
  .tab-btn.active { color: var(--mauve); border-bottom-color: var(--mauve); }

  /* ===== 記事リスト ===== */
  .post-list { display: flex; flex-direction: column; }

  .post-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.4rem;
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--border);
    align-items: start;
  }
  .post-item:first-child { padding-top: 0; }

  .post-thumb-wrap { position: relative; overflow: hidden; border-radius: var(--radius); }
  .post-thumb {
    width: 100%; height: 136px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  .post-item:hover .post-thumb { transform: scale(1.04); }
  .post-cat-badge {
    position: absolute;
    top: 0.5rem; left: 0.5rem;
    background: var(--mauve);
    color: var(--white);
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.12rem 0.55rem;
    letter-spacing: 0.03em;
  }

  .post-body { display: flex; flex-direction: column; gap: 0.45rem; }
  .post-date { font-size: 0.73rem; color: var(--grey-olive); }
  .post-title {
    font-family: 'Noto Serif JP', serif;
    font-size: 0.97rem;
    font-weight: 700;
    line-height: 1.65;
    color: var(--mauve);
  }
  .post-title a { color: var(--mauve); }
  .post-title a:hover { color: var(--dim-grey); }
  .post-excerpt {
    font-size: 0.81rem;
    color: var(--dim-grey);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-more {
    font-size: 0.76rem;
    color: var(--grey-olive);
    font-weight: 700;
  }
  .post-more::after { content: " →"; }
  .post-more:hover { color: var(--mauve); }

  @media (max-width: 600px) {
    .slide { min-width: 80%; }
    .post-item { grid-template-columns: 1fr; }
    .slider-section { margin: 0 -1rem 2rem; }
  }
</style>

<!-- SWELL風スライダー（ヘッダー直下・全幅） -->
<div class="slider-section">
  <div style="position:relative;">
    <div class="slider-track" id="sliderTrack">
      <div class="slide" onclick="location.href='/posts/soelu-review/'">
        <img class="slide-img" src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=600&h=440&q=80" alt="ヨガ">
        <div class="slide-overlay">
          <span class="slide-cat">ヨガ体験談</span>
          <div class="slide-title">【体が硬い・体調不安な私でも】SOELUオンラインヨガを試した正直な体験談</div>
        </div>
      </div>
      <div class="slide">
        <img class="slide-img" src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&w=600&h=440&q=80" alt="ウェルネス">
        <div class="slide-overlay">
          <span class="slide-cat">ウェルネス習慣</span>
          <div class="slide-title">おうち時間を整える、40〜50代のウェルネス習慣</div>
        </div>
      </div>
      <div class="slide">
        <img class="slide-img" src="https://images.unsplash.com/photo-1599901860904-17e6ed7083a0?auto=format&fit=crop&w=600&h=440&q=80" alt="ヨガマット">
        <div class="slide-overlay">
          <span class="slide-cat">初心者ガイド</span>
          <div class="slide-title">ヨガマット1枚から始める、おうちウェルネスのはじめかた</div>
        </div>
      </div>
      <div class="slide">
        <img class="slide-img" src="https://images.unsplash.com/photo-1510894347713-fc3dc6166ef5?auto=format&fit=crop&w=600&h=440&q=80" alt="朝のヨガ">
        <div class="slide-overlay">
          <span class="slide-cat">ヨガ体験談</span>
          <div class="slide-title">朝5分でできる、体が硬い人のための目覚めストレッチ</div>
        </div>
      </div>
      <div class="slide">
        <img class="slide-img" src="https://images.unsplash.com/photo-1552196563-55cd4e45efb3?auto=format&fit=crop&w=600&h=440&q=80" alt="リラックス">
        <div class="slide-overlay">
          <span class="slide-cat">ウェルネス習慣</span>
          <div class="slide-title">疲れを翌日に持ち越さない、夜のリラックスルーティン</div>
        </div>
      </div>
    </div>
    <button class="slider-btn prev" onclick="changeSlide(-1)">‹</button>
    <button class="slider-btn next" onclick="changeSlide(1)">›</button>
  </div>
  <div class="slider-nav" id="sliderDots">
    <button class="dot active" onclick="goSlide(0)"></button>
    <button class="dot" onclick="goSlide(1)"></button>
    <button class="dot" onclick="goSlide(2)"></button>
  </div>
</div>

<!-- タブ -->
<div class="tab-wrap">
  <button class="tab-btn active">新着記事</button>
  <button class="tab-btn">人気記事</button>
</div>

<!-- 記事リスト -->
<div class="post-list">
  {% for post in collections.posts %}
  <article class="post-item">
    <div class="post-thumb-wrap">
      <img class="post-thumb"
        src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=400&h=272&q=80"
        alt="{{ post.data.title }}">
      <span class="post-cat-badge">ヨガ体験談</span>
    </div>
    <div class="post-body">
      <div class="post-date">{{ post.date | dateJP }}</div>
      <h2 class="post-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
      {% if post.data.description %}
      <p class="post-excerpt">{{ post.data.description }}</p>
      {% endif %}
      <a href="{{ post.url }}" class="post-more">続きを読む</a>
    </div>
  </article>
  {% endfor %}
</div>

<script>
  let current = 0;
  const visibleCount = window.innerWidth <= 600 ? 1 : 3;
  const slides = document.querySelectorAll('.slide');
  const total = slides.length;
  const track = document.getElementById('sliderTrack');

  function goSlide(n) {
    const max = total - visibleCount;
    current = Math.max(0, Math.min(n, max));
    const w = slides[0].offsetWidth;
    track.style.transform = `translateX(-${current * w}px)`;
    document.querySelectorAll('.dot').forEach((d, i) => d.classList.toggle('active', i === current));
  }
  function changeSlide(dir) { goSlide(current + dir); }

  // 自動スライド
  setInterval(() => {
    const max = total - (window.innerWidth <= 600 ? 1 : 3);
    goSlide(current >= max ? 0 : current + 1);
  }, 4000);

  // タッチ操作
  let startX = 0;
  track.addEventListener('touchstart', e => startX = e.touches[0].clientX);
  track.addEventListener('touchend', e => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) changeSlide(diff > 0 ? 1 : -1);
  });
</script>

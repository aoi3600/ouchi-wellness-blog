---
layout: base.njk
title: ホーム
description: おうちヨガ・ウェルネスで毎日を整える。40〜50代女性のためのリアルな体験ブログ。
---

<style>
  /* ===== スライダー ===== */
  .slider-wrap {
    position: relative;
    overflow: hidden;
    margin-bottom: 3rem;
    border-radius: var(--radius);
    background: var(--gray5);
  }
  .slider-track {
    display: flex;
    transition: transform 0.5s ease;
  }
  .slide {
    min-width: 100%;
    position: relative;
    cursor: pointer;
  }
  .slide-img {
    width: 100%;
    height: 360px;
    object-fit: cover;
    display: block;
  }
  .slide-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.65));
    padding: 2rem 1.8rem 1.5rem;
    color: var(--white);
  }
  .slide-cat {
    display: inline-block;
    background: var(--white);
    color: var(--black);
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.15rem 0.7rem;
    margin-bottom: 0.6rem;
    letter-spacing: 0.04em;
  }
  .slide-title {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.6;
    color: var(--white);
  }

  /* スライダーナビ */
  .slider-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8rem 0;
    background: var(--white);
  }
  .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--gray4);
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    padding: 0;
  }
  .dot.active { background: var(--black); }
  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.85);
    border: none;
    width: 36px; height: 36px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    z-index: 10;
  }
  .slider-btn:hover { background: var(--white); }
  .slider-btn.prev { left: 1rem; }
  .slider-btn.next { right: 1rem; }

  /* ===== タブ ===== */
  .tab-wrap {
    display: flex;
    border-bottom: 2px solid var(--gray4);
    margin-bottom: 1.5rem;
    gap: 0;
  }
  .tab-btn {
    padding: 0.7rem 1.8rem;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--gray3);
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: all 0.15s;
  }
  .tab-btn.active {
    color: var(--black);
    border-bottom-color: var(--black);
  }

  /* ===== 記事リスト（横並び） ===== */
  .post-list { display: flex; flex-direction: column; gap: 0; }

  .post-item {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 1.5rem;
    padding: 1.8rem 0;
    border-bottom: 1px solid var(--gray4);
    align-items: start;
    transition: opacity 0.2s;
  }
  .post-item:first-child { padding-top: 0; }
  .post-item:hover { opacity: 0.85; }

  .post-thumb-wrap { position: relative; overflow: hidden; border-radius: 4px; }
  .post-thumb {
    width: 100%;
    height: 150px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  .post-item:hover .post-thumb { transform: scale(1.03); }
  .post-cat-badge {
    position: absolute;
    top: 0.5rem; left: 0.5rem;
    background: var(--black);
    color: var(--white);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.15rem 0.6rem;
    letter-spacing: 0.03em;
  }

  .post-body { display: flex; flex-direction: column; gap: 0.5rem; }
  .post-date { font-size: 0.75rem; color: var(--gray3); }
  .post-title {
    font-family: 'Noto Serif JP', serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.65;
    color: var(--black);
  }
  .post-excerpt {
    font-size: 0.83rem;
    color: var(--gray2);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-more {
    font-size: 0.78rem;
    color: var(--accent);
    font-weight: 700;
    margin-top: 0.2rem;
  }
  .post-more::after { content: " →"; }

  @media (max-width: 600px) {
    .post-item { grid-template-columns: 1fr; }
    .slide-img { height: 220px; }
    .slide-title { font-size: 1rem; }
  }
</style>

<!-- スライダー -->
<div class="slider-wrap">
  <div class="slider-track" id="sliderTrack">
    <div class="slide" onclick="location.href='/posts/soelu-review/'">
      <img class="slide-img" src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=1200&h=720&q=80" alt="ヨガ">
      <div class="slide-overlay">
        <span class="slide-cat">ヨガ体験談</span>
        <div class="slide-title">【体が硬い・体調不安な私でも】<br>SOELUオンラインヨガを試した正直な体験談</div>
      </div>
    </div>
    <div class="slide">
      <img class="slide-img" src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&w=1200&h=720&q=80" alt="ウェルネス">
      <div class="slide-overlay">
        <span class="slide-cat">ウェルネス習慣</span>
        <div class="slide-title">おうち時間を整える、<br>40〜50代のウェルネス習慣</div>
      </div>
    </div>
    <div class="slide">
      <img class="slide-img" src="https://images.unsplash.com/photo-1599901860904-17e6ed7083a0?auto=format&fit=crop&w=1200&h=720&q=80" alt="ヨガマット">
      <div class="slide-overlay">
        <span class="slide-cat">初心者ガイド</span>
        <div class="slide-title">ヨガマット1枚から始める、<br>おうちウェルネスのはじめかた</div>
      </div>
    </div>
  </div>
  <button class="slider-btn prev" onclick="changeSlide(-1)">‹</button>
  <button class="slider-btn next" onclick="changeSlide(1)">›</button>
  <div class="slider-dots">
    <button class="dot active" onclick="goSlide(0)"></button>
    <button class="dot" onclick="goSlide(1)"></button>
    <button class="dot" onclick="goSlide(2)"></button>
  </div>
</div>

<!-- タブ -->
<div class="tab-wrap">
  <button class="tab-btn active">新着記事</button>
  <button class="tab-btn">人気記事</button>
</div>

<!-- 記事リスト -->
<div class="post-list">
  {% for post in collections.posts %}
  <article class="post-item">
    <div class="post-thumb-wrap">
      <img class="post-thumb"
        src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=440&h=300&q=80"
        alt="{{ post.data.title }}">
      <span class="post-cat-badge">ヨガ体験談</span>
    </div>
    <div class="post-body">
      <div class="post-date">{{ post.date | dateJP }}</div>
      <h2 class="post-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
      {% if post.data.description %}
      <p class="post-excerpt">{{ post.data.description }}</p>
      {% endif %}
      <a href="{{ post.url }}" class="post-more">続きを読む</a>
    </div>
  </article>
  {% endfor %}
</div>

<script>
  let current = 0;
  const total = 3;
  const track = document.getElementById('sliderTrack');
  const dots = document.querySelectorAll('.dot');

  function goSlide(n) {
    current = n;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }
  function changeSlide(dir) {
    goSlide((current + dir + total) % total);
  }

  // 自動スライド（4秒）
  setInterval(() => changeSlide(1), 4000);
</script>
